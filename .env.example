# Jesse Trading Bot Configuration
# Copy this file to .env and customize

# Exchange (ccxt id, e.g. binance, bybit, coinbase)
EXCHANGE=binance

# API Credentials - KEEP SECRET! Use testnet for safety
API_KEY=
API_SECRET=

# Trading pair and timeframe
SYMBOL=BTC/USDT
TIMEFRAME=1h

# Modes
PAPER_TRADING=true
DRY_RUN=true

# Risk Management
MAX_POSITION_PCT=0.02
RISK_PER_TRADE_PCT=0.01
DAILY_LOSS_LIMIT_PCT=0.05

# Example SMA Strategy params
SMA_FAST=9
SMA_SLOW=21
